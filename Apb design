`define size 8
`define depth 64
`define addr_width $clog2(`depth)
module apb_master(
  input [`addr_width-1:0]add,//from soc
  output psel,
  input reset,
  input clk,
  input [`addr_width-1:0]addr,
  input wrt_rd,
  input[`size-1:0]wdata,
  input [`size-1:0]rdata,
  input ready,
  output reg [`size-1:0]rout,
  output reg reset_out,
  output reg penable,
  output reg[`addr_width-1:0]addr_out,
  output reg wrt_rd_out,
  output reg[`size-1:0]wdata_out,
  output reg valid,
  output reg psel_out);
  reg valid_d;
  assign psel=(add>31)?1:0;
  always@(posedge clk)begin
  valid_d<=valid;
  penable<=valid_d;
  reset_out<=reset;
  wrt_rd_out<=wrt_rd;
   psel_out<=psel; 
    if(reset)begin
      rout<=0;
      wdata_out<=0;
      addr_out<=0;
      valid<=0;
      psel_out<=0;
    end
    else begin
      if(!valid && wrt_rd)begin
      rout<=0;
      wdata_out<=wdata;
      addr_out<=addr;
      valid<=1;
      end
      else if(!valid && !wrt_rd)begin
      rout<=rdata;
      wdata_out<=wdata;
      addr_out<=addr;
      valid<=1;
      
      end
      else if(valid && ready && penable)begin
        valid<=0;
      end
    end
  end
endmodule
  
module apb_mux(input psel,
               input[`size-1:0]rdata1,
               input [`size-1:0]rdata2,
               input ready1,
               input ready2,
               output reg ready_out,
               output reg [`size-1:0]rdata_out);
  always@(*)begin
    case(psel)
      0:begin rdata_out=rdata1;ready_out=ready1  ;end
        1:begin rdata_out=rdata2;ready_out=ready2 ;end
    endcase
  end
endmodule
  
module mem_mod1
  #(parameter int size=`size,
    parameter int depth=`depth,
    parameter int add_width=`addr_width)
  (
  input  logic                 wrtrd_en,
  input  logic                 valid,
  input  logic                 clk,
  input  logic                 reset,
  input  logic [add_width-1:0] add,
  input  logic [size-1:0]      data,
  output logic [size-1:0]      out,
  output logic                 ready,
   input logic penable,
  input psel);

  logic [size-1:0] mem [0:depth-1];

  always_ff @(posedge clk) begin
  
    if (reset) begin
      for (int i=0; i<depth; i++) 
      mem[i] <= '0;
      out   <= '0;
      ready <= 1'b0;
    end else  begin
      ready <= 1'b0;
      if (valid && !psel) begin
        ready <= 1'b1;
        if (wrtrd_en && penable) begin
          mem[add] <= data;
          $display("w_out is %d",mem[add]);
          out <= '0;
        end else if(!wrtrd_en && penable)begin
          out <= mem[add];
          $display("r_out is %d",out);
        end
      end
    end
  end
endmodule

module mem_mod2
  #(parameter int size=`size,
    parameter int depth=`depth,
    parameter int add_width=`addr_width)
  (
  input  logic                 wrtrd_en,
  input  logic                 valid,
  input  logic                 clk,
  input  logic                 reset,
  input  logic [add_width-1:0] add,
  input  logic [size-1:0]      data,
  output logic [size-1:0]      out,
  output logic                 ready,
   input logic penable,
  input logic psel);

  logic [size-1:0] mem [0:depth-1];

  always_ff @(posedge clk) begin
  
    if (reset) begin
      for (int i=0; i<depth; i++) 
      mem[i] <= '0;
      out   <= '0;
      ready <= 1'b0;
    end else  begin
      ready <= 1'b0;
      if (valid && psel) begin
        ready <= 1'b1;
        if (wrtrd_en && penable) begin
          mem[add] <= data;
          $display("w_out is %d",mem[add]);
          out <= '0;
        end else if(!wrtrd_en && penable)begin
          out <= mem[add];
          $display("r_out is %d",out);
        end
      end
    end
  end
endmodule

module apb_top(input reset,
              input clk,output psel,
              input [`addr_width-1:0]addr,
              input wrt_rd,
              input [`size-1:0]wdata,
               input [`addr_width-1:0]add,
               output [`size-1:0]out,
               output valid,
              output ready);
  wire en;
  wire  [`addr_width-1:0] addr_out;
  wire  [`size-1:0]  data,wdata_out,rdata_out;
  wire  [`size-1:0]  out1,out2,out3;
  wire   ready1,ready2;
  wire s_psel;
  wire  penable; 
  apb_master dut(add,psel,reset,clk,addr,wrt_rd,wdata,out3,ready,rdata_out,reset_out,penable,addr_out,en,wdata_out,valid,s_psel);
  apb_mux dut3(psel,out1,out2,ready1,ready2,ready,out3);
  mem_mod1 dut1(en,valid,clk,reset,addr_out,wdata_out,out1,ready1,penable,s_psel);
  mem_mod2 dut2(en,valid,clk,reset,addr_out,wdata_out,out2,ready2,penable,s_psel);
assign out=out3;
endmodule

