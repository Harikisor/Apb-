


module mux(
  input ready1,
  input ready2,
  input[`size-1:0] rdata1,
  input[`size-1:0] rdata2,
  input psel,
  input psel1,
  output reg ready,
  output reg [`size-1:0] rdata
);
  always@(*)begin
 case({psel, psel1})
    2'b10: begin
        ready = ready1; 
        rdata = rdata1;
    end
    2'b01: begin
        ready = ready2;
        rdata = rdata2;
    end
    default: begin
        ready = 0;
        rdata = 0;
    end
  endcase
end
endmodule

